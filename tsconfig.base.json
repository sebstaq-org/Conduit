{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@conduit/app-client": ["./packages/app-client/src/index.ts"],
      "@conduit/app-core": ["./packages/app-core/src/index.ts"],
      "@conduit/desktop/preload": ["./apps/desktop/src/preload/index.ts"],
      "@conduit/design-system-desktop": [
        "./packages/design-system-desktop/src/index.ts"
      ],
      "@conduit/design-system-mobile": [
        "./packages/design-system-mobile/src/index.ts"
      ],
      "@conduit/design-system-tokens": [
        "./packages/design-system-tokens/src/index.ts"
      ],
      "@conduit/session-client": ["./packages/session-client/src/index.ts"],
      "@conduit/session-contracts": [
        "./packages/session-contracts/src/index.ts"
      ],
      "@conduit/session-model": ["./packages/session-model/src/index.ts"],
      "@conduit/mobile/bootstrap": ["./apps/mobile/src/index.ts"]
    },
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": false,
    "types": ["node"]
  }
}
