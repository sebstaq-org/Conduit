{
  "name": "conduit",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "24.14.0",
    "pnpm": "10.30.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ],
    "overrides": {
      "react-native-enriched-markdown": "0.5.0-nightly-20260411-ba4bccd83",
      "react-native-reanimated": "4.3.0",
      "react-native-worklets": "0.8.1"
    },
    "patchedDependencies": {
      "metro@0.83.5": "apps/frontend/patches/metro@0.83.5.patch",
      "react-native-streamdown@0.1.1": "apps/frontend/patches/react-native-streamdown@0.1.1.patch",
      "react-native-reanimated@4.3.0": "apps/frontend/patches/react-native-reanimated@4.3.0.patch"
    }
  },
  "scripts": {
    "bootstrap": "cargo run --quiet --locked --manifest-path backend/service/Cargo.toml -p repo-guard -- bootstrap",
    "build": "tsc -b tsconfig.json",
    "clean": "cargo run --quiet --locked --manifest-path backend/service/Cargo.toml -p repo-guard -- clean",
    "desktop:build": "pnpm --filter @conduit/desktop run build",
    "desktop:dev": "pnpm --filter @conduit/desktop run dev",
    "desktop:lint": "pnpm --filter @conduit/desktop run lint",
    "desktop:test": "pnpm --filter @conduit/desktop run test",
    "desktop:typecheck": "pnpm --filter @conduit/desktop run typecheck",
    "format": "prettier . --write && cargo fmt --manifest-path backend/service/Cargo.toml --all",
    "format:check": "prettier . --check && cargo fmt --manifest-path backend/service/Cargo.toml --all --check",
    "fixtures:check": "cargo test --manifest-path backend/service/Cargo.toml -p acp-contracts --test protocol_captures && cargo test --manifest-path backend/service/Cargo.toml -p acp-core --test golden_testdata",
    "lint": "oxlint oxlint.config.ts vitest.config.ts scripts packages --deny-warnings",
    "frontend:android": "pnpm --filter @conduit/frontend run android",
    "frontend:doctor": "pnpm --filter @conduit/frontend run doctor",
    "frontend:ios": "pnpm --filter @conduit/frontend run ios",
    "frontend:lint": "pnpm --filter @conduit/frontend run lint",
    "frontend:start": "pnpm --filter @conduit/frontend run start",
    "frontend:test": "pnpm --filter @conduit/frontend run test",
    "frontend:typecheck": "pnpm --filter @conduit/frontend run typecheck",
    "frontend:web": "pnpm --filter @conduit/frontend run web",
    "stage:refresh": "bash scripts/stage/conduit-stage.sh refresh",
    "stage:start": "bash scripts/stage/conduit-stage.sh start",
    "stage:stop": "bash scripts/stage/conduit-stage.sh stop",
    "stage:status": "bash scripts/stage/conduit-stage.sh status",
    "stage:open": "bash scripts/stage/conduit-stage.sh open",
    "stage:logs": "bash scripts/stage/conduit-stage.sh logs",
    "stage:install-desktop-entry": "bash scripts/stage/conduit-stage.sh install-desktop-entry",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "vitest run && cargo test --manifest-path backend/service/Cargo.toml --workspace",
    "toolchain:check": "cargo run --quiet --locked --manifest-path backend/service/Cargo.toml -p repo-guard -- toolchain-check",
    "structure:check": "cargo run --quiet --locked --manifest-path backend/service/Cargo.toml -p repo-guard -- structure-check",
    "rust:build": "cargo build --manifest-path backend/service/Cargo.toml --workspace",
    "rust:clippy": "cargo clippy --manifest-path backend/service/Cargo.toml --workspace --all-targets --all-features -- -D warnings",
    "rust:doc": "RUSTDOCFLAGS='-D warnings' cargo doc --manifest-path backend/service/Cargo.toml --workspace --no-deps",
    "rust:metadata": "cargo metadata --manifest-path backend/service/Cargo.toml --format-version 1 > /dev/null",
    "check": "pnpm run toolchain:check && pnpm run structure:check && pnpm run fixtures:check && pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run build && pnpm run desktop:typecheck && pnpm run desktop:lint && pnpm run desktop:test && pnpm run desktop:build && pnpm run frontend:typecheck && pnpm run frontend:lint && pnpm run frontend:test && pnpm run frontend:doctor && pnpm run rust:metadata && pnpm run rust:clippy && pnpm run rust:doc && pnpm run rust:build && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "prettier": "3.8.2",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
