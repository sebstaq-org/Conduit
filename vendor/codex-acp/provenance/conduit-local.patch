+fn extract_user_input_response_answer(meta: &Meta, question_id: &str) -> Option<String> {
+    let response = meta.get(REQUEST_USER_INPUT_RESPONSE_META_KEY)?;
+    let answers = response.get("answers")?.as_object()?;
+    let question_answers = answers.get(question_id)?.get("answers")?.as_array()?;
+    question_answers
+        .iter()
+        .filter_map(|entry| entry.as_str())
+        .map(str::trim)
+        .find(|entry| !entry.is_empty())
+        .map(ToOwned::to_owned)
+}
+
+fn extract_other_user_input_answer(
+    question_id: &str,
+    selected_meta: Option<&Meta>,
+    response_meta: Option<&Meta>,
+) -> Option<String> {
+    selected_meta
+        .and_then(|meta| extract_user_input_response_answer(meta, question_id))
+        .or_else(|| {
+            response_meta.and_then(|meta| extract_user_input_response_answer(meta, question_id))
+        })
+}
+
+fn resolve_user_input_selected_answer(
+    question: &RequestUserInputQuestion,
+    option_map: &HashMap<String, String>,
+    selected: &SelectedPermissionOutcome,
+    response_meta: Option<&Meta>,
+) -> Result<String, UserInputSelectionError> {
+    let option_id = selected.option_id.0.as_ref();
+    if option_id == "answer-other" {
+        return extract_other_user_input_answer(
+            question.id.as_str(),
+            selected.meta.as_ref(),
+            response_meta,
+        )
+        .ok_or(UserInputSelectionError::MissingOtherText);
+    }
+
+    option_map
+        .get(option_id)
+        .cloned()
+        .ok_or(UserInputSelectionError::InvalidOptionId)
+}
