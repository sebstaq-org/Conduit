+
+fn terminal_plan_meta_value(update: &TerminalPlanUpdate) -> Meta {
+    let mut terminal_plan = serde_json::Map::new();
+    terminal_plan.insert("source".to_string(), json!(update.source.as_str()));
+    terminal_plan.insert("text".to_string(), json!(&update.text));
+    if let Some(item_id) = &update.item_id {
+        terminal_plan.insert("itemId".to_string(), json!(item_id));
+    }
+    if let Some(turn_id) = &update.turn_id {
+        terminal_plan.insert("turnId".to_string(), json!(turn_id));
+    }
+    if let Some(thread_id) = &update.thread_id {
+        terminal_plan.insert("threadId".to_string(), json!(thread_id));
+    }
+    if let Some(phase) = update.phase {
+        terminal_plan.insert("phase".to_string(), json!(phase));
+    }
+
+    let mut codex = serde_json::Map::new();
+    codex.insert(
+        CODEX_TERMINAL_PLAN_META_KEY.to_string(),
+        serde_json::Value::Object(terminal_plan),
+    );
+
+    let mut meta = Meta::new();
+    meta.insert("codex".to_string(), serde_json::Value::Object(codex));
+    meta
+}
