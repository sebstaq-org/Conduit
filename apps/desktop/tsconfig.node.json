{
  "extends": "../../tsconfig.base.json",
  "include": [
    "electron.vite.config.ts",
    "../../packages/app-client/src/**/*.ts",
    "../../packages/design-system-tokens/src/**/*.ts",
    "../../packages/session-client/src/**/*.ts",
    "../../packages/app-protocol/src/**/*.ts",
    "src/proof-config.ts",
    "src/main/**/*",
    "src/preload/**/*",
    "vitest.config.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "ignoreDeprecations": "5.0",
    "lib": ["ES2024"],
    "skipLibCheck": true,
    "types": ["electron-vite/node", "node"]
  }
}
