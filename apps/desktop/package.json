{
  "name": "@conduit/desktop",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "pnpm run typecheck && electron-vite build",
    "dev": "electron-vite dev --noSandbox",
    "lint": "oxlint . --config ../../oxlint.config.ts --deny-warnings",
    "package:stage": "electron-forge package --platform=linux --arch=x64",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@conduit/app-client": "workspace:*",
    "@conduit/app-core": "workspace:*",
    "@conduit/design-system-tokens": "workspace:*",
    "@conduit/session-client": "workspace:*",
    "@conduit/session-contracts": "workspace:*",
    "@conduit/session-model": "workspace:*",
    "qrcode": "1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.1",
    "@electron-forge/maker-zip": "7.11.1",
    "@electron-forge/shared-types": "7.11.1",
    "@swc/core": "1.15.24",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "electron": "41.2.0",
    "electron-vite": "5.0.0",
    "typescript": "~5.9.2",
    "vite": "7.3.1",
    "vitest": "4.1.4"
  }
}
