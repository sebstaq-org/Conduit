{
  "extends": "../../tsconfig.base.json",
  "include": [
    "../../packages/app-client/src/**/*.ts",
    "../../packages/app-core/src/**/*.ts",
    "../../packages/design-system-tokens/src/**/*.ts",
    "../../packages/session-client/src/**/*.ts",
    "../../packages/app-protocol/src/**/*.ts",
    "src/renderer/**/*",
    "vitest.config.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "ignoreDeprecations": "5.0",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "skipLibCheck": true,
    "types": ["vite/client"]
  }
}
