{
  "cli": {
    "version": ">=16.24.0",
    "appVersionSource": "local"
  },
  "build": {
    "stage-simulator": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "stage"
      },
      "ios": {
        "simulator": true
      }
    },
    "stage": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "stage"
      },
      "ios": {
        "simulator": false
      }
    }
  }
}
