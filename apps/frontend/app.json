{
  "expo": {
    "name": "Conduit",
    "slug": "conduit",
    "version": "0.5.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "scheme": "conduit",
    "android": {
      "package": "org.sebstaq.conduit"
    },
    "plugins": [
