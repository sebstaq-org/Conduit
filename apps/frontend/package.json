{
  "name": "@conduit/frontend",
  "private": true,
  "version": "0.5.0",
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo run:android",
    "doctor": "pnpm exec expo-doctor",
    "ios": "expo run:ios",
    "lint": "oxlint . --config ../../oxlint.config.ts --deny-warnings",
    "start": "expo start",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "web": "expo start --web"
  },
  "dependencies": {
    "@conduit/design-system-tokens": "workspace:*",
    "@conduit/session-client": "workspace:*",
    "@conduit/session-contracts": "workspace:*",
    "@conduit/session-model": "workspace:*",
    "@expo/vector-icons": "15.1.1",
    "@reduxjs/toolkit": "2.11.2",
    "@shopify/restyle": "^2.4.5",
    "expo": "~55.0.14",
    "expo-constants": "~55.0.13",
    "expo-font": "~55.0.6",
    "expo-linking": "~55.0.12",
    "expo-router": "~55.0.12",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-drawer-layout": "4.2.2",
    "react-native-enriched-markdown": "0.5.0-nightly-20260411-ba4bccd83",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.3.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-streamdown": "0.1.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.1",
    "react-redux": "9.2.0",
    "remend": "1.2.2"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@types/react": "~19.2.2",
    "expo-doctor": "1.18.18",
    "typescript": "~5.9.2",
    "vitest": "4.1.4"
  },
  "worklets": {
    "staticFeatureFlags": {
      "BUNDLE_MODE_ENABLED": true
    }
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-reanimated",
        "react-native-worklets"
      ]
    },
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  }
}
