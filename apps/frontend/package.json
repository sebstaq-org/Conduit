{
  "name": "@conduit/frontend",
  "private": true,
  "version": "0.5.0",
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo start --android",
    "doctor": "pnpm exec expo-doctor",
    "ios": "expo start --ios",
    "lint": "oxlint . --config ../../oxlint.config.ts --deny-warnings",
    "start": "expo start",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "web": "expo start --web"
  },
  "dependencies": {
    "@conduit/design-system-tokens": "workspace:*",
    "@conduit/session-client": "workspace:*",
    "@conduit/session-contracts": "workspace:*",
    "@conduit/session-model": "workspace:*",
    "@expo/vector-icons": "15.1.1",
    "expo": "~55.0.14",
    "expo-constants": "~55.0.13",
    "expo-linking": "~55.0.12",
    "expo-router": "~55.0.12",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "expo-doctor": "1.18.18",
    "typescript": "~5.9.2",
    "vitest": "4.1.4"
  }
}
